# Copy this file to .env and adjust values before running docker compose
# cp .env.docker.example .env

# Node environment (development | production)
NODE_ENV=production

# Port exposed on the host machine (maps to nginx port 80 inside the container)
VITE_PORT=3000

# Backend API base URL reachable from the browser
# When running the backend in the same Docker network, use the service name:
#   e.g. http://hris-backend:8000
VITE_API_URL=http://localhost:8000

# Application display name
VITE_APP_NAME=HRIS Company
